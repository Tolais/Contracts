# Backup Configuration Template
# Copy this file to .env.backup and fill in your values

# PostgreSQL Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stellar_protocol
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# AWS S3 Configuration
AWS_BUCKET=your-protocol-backups
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Encryption Configuration (base64 encoded 32-byte key)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here

# Fire Drill Configuration (optional)
FIRE_DRILL_RECOVERY_HOST=localhost
FIRE_DRILL_RECOVERY_PORT=5433
